# Database
# 开发环境可用 SQLite: DATABASE_PROVIDER="sqlite" DATABASE_URL="file:./dev.db"
# 生产环境使用 PostgreSQL: DATABASE_PROVIDER="postgresql" DATABASE_URL="postgresql://..."
DATABASE_PROVIDER="postgresql"
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT (生成：openssl rand -base64 32)
JWT_SECRET=minimum-32-characters-for-security
JWT_EXPIRES_IN=7d

# IoT
TCP_PORT=5858
