# ============================================
# FHDTS - 居家健康数字孪生系统 环境变量配置
# ============================================

# 说明：
# 1. 开发环境：无需配置即可运行，自动使用SQLite
# 2. 生产环境：使用Docker Compose内部的固定PostgreSQL实例
# 3. 变量优先级：.env文件 > 系统环境变量 > 默认值

# ================= 运行环境 =================
# 运行环境：development(开发) | production(生产) | test(测试)
# 开发环境：自动使用SQLite数据库
# 生产环境：自动使用Docker Compose内部的PostgreSQL
NODE_ENV=development

# ================= 服务器配置 =================
# 服务器端口
PORT=3000

# ================= 安全配置 =================
# JWT 签名密钥（至少32个字符）
# 开发环境：使用默认值
# 生产环境：必须设置（通过GitHub Secrets或环境变量）
# 生成命令：openssl rand -base64 32
JWT_SECRET=development-jwt-secret-minimum-32-characters-long

# JWT 过期时间（支持 days/hours/minutes 格式）
JWT_EXPIRES_IN=7d

# ================= 跨域配置 =================
# CORS 允许的源
# 开发环境默认：http://localhost:5173
# 生产环境：根据实际前端地址设置
CORS_ORIGIN=http://localhost:5173

# ================= 前端配置 =================
# 前端 API 地址（Vite 要求 VITE_ 前缀）
# 开发环境默认：http://localhost:3000
# 生产环境：设置为实际域名或相对路径
VITE_API_URL=http://localhost:3000

# 应用标题（可选）
VITE_APP_TITLE=Digital Twin

# ================= 数据库配置说明 =================
# 注意：数据库配置已自动化，无需手动设置DATABASE_URL
#
# 开发环境 (NODE_ENV=development):
#   - 自动使用SQLite数据库：file:./dev.db
#   - 无需安装PostgreSQL
#   - 数据存储在项目根目录的dev.db文件中
#
# 生产环境 (NODE_ENV=production):
#   - 自动使用Docker Compose内部的PostgreSQL
#   - 固定连接：postgresql://digitaltwin:digitaltwin_prod_password@postgres:5432/digitaltwin
#   - 数据库不对外暴露端口，仅内部访问
#   - 可通过SSH隧道连接进行维护
#
# 测试环境 (NODE_ENV=test):
#   - 需要手动设置DATABASE_URL
#   - 建议使用测试专用的数据库

# ================= SSH隧道连接示例 =================
# 如需通过SSH连接生产环境的PostgreSQL进行维护：
#
# 1. 建立SSH隧道：
#    ssh -L 5432:localhost:5432 user@server -N
#
# 2. 使用数据库客户端连接：
#    主机：localhost
#    端口：5432
#    用户名：digitaltwin
#    密码：digitaltwin_prod_password
#    数据库：digitaltwin
#
# 3. 注意：生产环境数据库不对外网开放，仅通过SSH隧道访问

# ============================================
# 使用说明：
#
# 开发环境：
#   1. 直接运行 `pnpm dev` 即可
#   2. 无需创建 .env 文件
#   3. 自动使用SQLite数据库
#
# 生产环境部署：
#   1. 设置 NODE_ENV=production
#   2. 设置 JWT_SECRET（必须）
#   3. 其他变量可选
#   4. 数据库自动配置，无需设置DATABASE_URL
#
# 自定义配置：
#   如需覆盖默认配置，取消注释并修改上方变量
# ============================================
